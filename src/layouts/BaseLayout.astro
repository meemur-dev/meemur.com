---
import Header from "../layout/Header.astro";
import Footer from "../layout/Footer.astro";
import { useTranslations, localePath } from "../i18n/utils";
import type { Locale } from "../i18n/utils";
import "../styles/global.css";

export interface Props {
  title: string;
  description: string;
  canonical: string;
  pageClass: string;
  active?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  noindex?: boolean;
  includeTurnstile?: boolean;
  version?: string;
  locale?: Locale;
}

const {
  title,
  description,
  canonical,
  pageClass,
  active,
  ogTitle,
  ogDescription,
  ogImage,
  noindex,
  includeTurnstile,
  version,
  locale = "en",
} = Astro.props;

const ogTitleFinal = ogTitle || title;
const ogDescFinal = ogDescription || description;
const ogImageFinal = ogImage || "https://meemur.com/og-image.png";
const t = useTranslations(locale);
const langAttr = locale === "tr" ? "tr" : "en";
const ogLocale = t("og.locale");

const alternateLocales: Locale[] = locale === "en" ? ["tr"] : ["en"];

const canonicalPath = canonical ? new URL(canonical, "https://meemur.com").pathname : "/";
---

<!doctype html>
<html lang={langAttr}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Onur Yanar" />
    {canonical && <link rel="canonical" href={canonical} />}
    {noindex && <meta name="robots" content="noindex" />}
    {version && <meta name="version" content={version} />}

    {
      canonical && (
        <>
          <link rel="alternate" hreflang={locale} href={canonical} />
          {alternateLocales.map((alt) => (
            <link rel="alternate" hreflang={alt} href={`https://meemur.com${localePath(canonicalPath, alt)}`} />
          ))}
          <link rel="alternate" hreflang="x-default" href={`https://meemur.com${canonicalPath}`} />
        </>
      )
    }

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- LCP element: the header wordmark. Preload so the scanner fetches it before parsing the header. -->
    <link rel="preload" href="/logo-wordmark.svg" as="image" type="image/svg+xml" fetchpriority="high" />

    <link rel="preload" href="/fonts/montserrat-700.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/montserrat-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/montserrat-600.woff2" as="font" type="font/woff2" crossorigin />

    <link rel="expect" href="#main" blocking="render" />

    <meta property="og:title" content={ogTitleFinal} />
    <meta property="og:description" content={ogDescFinal} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="meemur" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:image" content={ogImageFinal} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitleFinal} />
    <meta name="twitter:description" content={ogDescFinal} />
    <meta name="twitter:image" content={ogImageFinal} />

    <meta name="theme-color" content="#00a9b8" />

    <script>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-ND4VP7H4");
    </script>

    {includeTurnstile && (
      <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    )}

    <script>
      import "../scripts/main.ts";
    </script>
  </head>
  <body class={pageClass}>
    <noscript
      ><iframe
        title="Google Tag Manager"
        src="https://www.googletagmanager.com/ns.html?id=GTM-ND4VP7H4"
        height="0"
        width="0"
        style="display: none; visibility: hidden"
      ></iframe
    ></noscript>

    <div class="bg" aria-hidden="true">
      <span class="blob blob--1"></span>
      <span class="blob blob--2"></span>
      <span class="blob blob--3"></span>
    </div>

    <Header active={active} locale={locale} />

    <main id="main">
      <slot />
    </main>

    <Footer locale={locale} />
  </body>
</html>
