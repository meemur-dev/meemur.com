---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/pages/about.css";
---

<BaseLayout
  title="About &amp; Contact · meemur"
  description="meemur is a founder-led boutique digital agency by Onur Yanar, with 10+ years in front-end, e-commerce and analytics. Get in touch about your project."
  canonical="https://meemur.com/about"
  pageClass="page-about"
  active="about"
  ogTitle="About &amp; Contact · meemur"
  ogDescription="Founder-led boutique digital agency by Onur Yanar. Get in touch about your project."
  includeTurnstile={true}
  locale="en"
>
  <section class="section page-hero">
    <div class="container">
      <p class="eyebrow">About</p>
      <h1>A boutique studio, built on craft and data</h1>
      <p class="lead">
        meemur is a small, founder-led digital agency. We pair senior front-end engineering
        with a measurement mindset, so what we build is both beautiful and accountable.
      </p>
    </div>
  </section>

  <section class="section about-founder">
    <div class="container">
      <div class="about-founder__inner">
        <div class="about-founder__text">
          <p class="eyebrow">The founder</p>
          <div class="about-founder__name">
            <img
              class="about-founder__avatar"
              src="/about/onur.webp"
              alt="Portrait of Onur Yanar"
              width="320"
              height="320"
              loading="lazy"
            />
            <h2>Onur Yanar</h2>
          </div>
          <p>
            I'm Onur, a web and analytics specialist with 10+ years of experience. I've built
            online stores and growth-tracking systems for 60+ brands, and I started meemur to do
            that work directly, without layers in between.
          </p>
          <p>
            My background blends engineering and statistics, so I care as much about how fast and
            welcoming your site feels as I do about the data behind every decision. When you work
            with meemur, you work with me.
          </p>
          <ul class="about-links" role="list">
            <li><a href="https://onuryanar.com/" rel="me noopener" target="_blank">onuryanar.com</a></li>
            <li><a href="https://www.linkedin.com/in/oyanar" rel="me noopener" target="_blank">LinkedIn</a></li>
            <li><a href="https://github.com/onurstats" rel="me noopener" target="_blank">GitHub</a></li>
          </ul>
        </div>
        <figure class="about-founder__photo">
          <img
            src="/about/office.webp"
            alt="The meemur studio storefront in Ankara, a glass-door entrance with signage reading “We make the web work for you.”"
            width="1424"
            height="1440"
            loading="lazy"
          />
          <figcaption>Our studio in Ankara</figcaption>
        </figure>
      </div>
      <ul class="values" role="list">
        <li class="value"><h3>Senior, hands-on</h3><p>You always work directly with the person doing the work.</p></li>
        <li class="value"><h3>Data over opinions</h3><p>Decisions are backed by clean analytics and testing.</p></li>
        <li class="value"><h3>Built to last</h3><p>Accessible, fast, maintainable code, no shortcuts.</p></li>
      </ul>
    </div>
  </section>

  <section class="section contact" id="contact">
    <div class="container contact__inner">
      <div class="contact__intro">
        <p class="eyebrow">Contact</p>
        <h2>Let's talk about your project</h2>
        <p>
          Tell us a little about what you're building and we'll reply within one business day.
          Prefer email? Reach us directly at
          <a href="mailto:contact@meemur.com">contact@meemur.com</a>.
        </p>
        <ul class="about-links" role="list">
          <li><a href="https://www.linkedin.com/company/meemur/" rel="me noopener" target="_blank">LinkedIn</a></li>
          <li><a href="https://github.com/meemur-dev" rel="me noopener" target="_blank">GitHub</a></li>
        </ul>
      </div>

      <form id="contact-form" class="contact-form" novalidate>
        <div class="field">
          <label for="cf-name">Name</label>
          <input id="cf-name" name="name" type="text" autocomplete="name" required />
        </div>
        <div class="field">
          <label for="cf-email">Email</label>
          <input id="cf-email" name="email" type="email" autocomplete="email" required />
        </div>
        <div class="field">
          <label for="cf-message">Message</label>
          <textarea id="cf-message" name="message" rows="5" required></textarea>
        </div>

        <div class="hp" aria-hidden="true">
          <label>Company<input name="company" type="text" tabindex="-1" autocomplete="off" /></label>
        </div>

        <div class="cf-turnstile" data-sitekey={import.meta.env.PUBLIC_TURNSTILE_SITEKEY || ""}></div>

        <button class="btn btn--primary" type="submit">Send message</button>
        <p id="contact-status" class="form-status" role="status" aria-live="polite"></p>
      </form>
    </div>
  </section>
</BaseLayout>
