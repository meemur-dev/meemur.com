---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/pages/services.css";
---

<BaseLayout
  title="Services · meemur"
  description="meemur's services: web &amp; e-commerce builds, analytics &amp; measurement, CRO &amp; experimentation, accessibility &amp; performance, and social media ads."
  canonical="https://meemur.com/services"
  pageClass="page-services"
  active="services"
  ogTitle="Services · meemur"
  ogDescription="Web &amp; e-commerce, analytics, CRO, accessibility &amp; performance, and social media ads."
  locale="en"
>
  <section class="section page-hero">
    <div class="container">
      <p class="eyebrow">Services</p>
      <h1>What we do</h1>
      <p class="lead">
        Six ways we help your brand grow. Take a project from start to finish, or bring us in
        for exactly the part you need.
      </p>
    </div>
  </section>

  <div class="container service-list">
    <section class="service" id="ecommerce">
      <div class="service__head">
        <span class="service__num">01</span>
        <h2 class="service__title">Web &amp; E-commerce builds</h2>
      </div>
      <p class="service__intro">
        Your website is your hardest-working salesperson. We craft beautiful, lightning-fast
        sites and online stores that turn visitors into customers, and make buying a breeze.
      </p>
      <div class="service__cols">
        <div>
          <h3 class="service__subhead">What you get</h3>
          <ul class="ticks" role="list">
            <li>Custom online stores on Shopify &amp; BigCommerce</li>
            <li>Modern, made-to-measure websites</li>
            <li>A polished, consistent look on every page</li>
            <li>Easy content editing you control yourself</li>
          </ul>
        </div>
        <div>
          <h3 class="service__subhead">Tools</h3>
          <ul class="tags" role="list">
            <li>React</li><li>Next.js</li><li>TypeScript</li><li>Shopify</li>
            <li>BigCommerce</li><li>Node.js</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="service" id="apps">
      <div class="service__head">
        <span class="service__num">02</span>
        <h2 class="service__title">Cross-platform App Development</h2>
      </div>
      <p class="service__intro">
        Be where your customers are: on their phones. We build polished apps for iPhone and
        Android that feel native, launch fast, and keep people coming back.
      </p>
      <div class="service__cols">
        <div>
          <h3 class="service__subhead">What you get</h3>
          <ul class="ticks" role="list">
            <li>One app for both iPhone and Android</li>
            <li>Fast, smooth, native-feeling experience</li>
            <li>Launch on the App Store &amp; Google Play</li>
            <li>Consistent with your website, end to end</li>
          </ul>
        </div>
        <div>
          <h3 class="service__subhead">Tools</h3>
          <ul class="tags" role="list">
            <li>React Native</li><li>Ionic</li><li>iOS</li><li>Android</li>
            <li>TypeScript</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="service" id="analytics">
      <div class="service__head">
        <span class="service__num">03</span>
        <h2 class="service__title">Analytics &amp; Measurement</h2>
      </div>
      <p class="service__intro">
        Stop guessing. We set up measurement you can rely on, then turn the numbers into
        plain-English insights that guide every decision.
      </p>
      <div class="service__cols">
        <div>
          <h3 class="service__subhead">What you get</h3>
          <ul class="ticks" role="list">
            <li>Accurate tracking set up and health-checked</li>
            <li>Know exactly how visitors shop and convert</li>
            <li>Clear dashboards and reports made for you</li>
            <li>See how real people use your site</li>
          </ul>
        </div>
        <div>
          <h3 class="service__subhead">Tools</h3>
          <ul class="tags" role="list">
            <li>GA4</li><li>Google Tag Manager</li><li>Clarity</li>
            <li>Looker Studio</li><li>BigQuery</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="service" id="cro">
      <div class="service__head">
        <span class="service__num">04</span>
        <h2 class="service__title">CRO &amp; Experimentation</h2>
      </div>
      <p class="service__intro">
        More revenue without more traffic. We find what's holding your visitors back, fix it,
        and prove the lift with real experiments.
      </p>
      <div class="service__cols">
        <div>
          <h3 class="service__subhead">What you get</h3>
          <ul class="ticks" role="list">
            <li>A clear picture of where you're losing sales</li>
            <li>Smart experiments that prove what works</li>
            <li>Trustworthy results, backed by the numbers</li>
            <li>A prioritised plan to lift conversions</li>
          </ul>
        </div>
        <div>
          <h3 class="service__subhead">Tools</h3>
          <ul class="tags" role="list">
            <li>A/B testing</li><li>GA4</li><li>Statistics</li><li>Heatmaps</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="service" id="performance">
      <div class="service__head">
        <span class="service__num">05</span>
        <h2 class="service__title">Accessibility &amp; Performance</h2>
      </div>
      <p class="service__intro">
        Slow sites lose customers. We make yours load in a blink and work beautifully for
        everyone, lifting both your sales and your search rankings.
      </p>
      <div class="service__cols">
        <div>
          <h3 class="service__subhead">What you get</h3>
          <ul class="ticks" role="list">
            <li>A site that works for every visitor</li>
            <li>Pages that load in a blink</li>
            <li>Speed tuned for real-world devices</li>
            <li>Better search rankings from a healthier site</li>
          </ul>
        </div>
        <div>
          <h3 class="service__subhead">Tools</h3>
          <ul class="tags" role="list">
            <li>WCAG 2.2</li><li>Lighthouse</li><li>Core Web Vitals</li><li>axe</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="service" id="ads">
      <div class="service__head">
        <span class="service__num">06</span>
        <h2 class="service__title">Social Media Ads</h2>
      </div>
      <p class="service__intro">
        Reach the right people at the right moment. We run scroll-stopping social campaigns and
        tie every click to real results, so you always know what your budget brings back.
      </p>
      <div class="service__cols">
        <div>
          <h3 class="service__subhead">What you get</h3>
          <ul class="ticks" role="list">
            <li>Campaigns across Meta and beyond</li>
            <li>Sharp targeting and scroll-stopping creative</li>
            <li>Every conversion accurately tracked</li>
            <li>Clear ROI reporting you can trust</li>
          </ul>
        </div>
        <div>
          <h3 class="service__subhead">Tools</h3>
          <ul class="tags" role="list">
            <li>Meta Ads</li><li>Conversions API</li><li>GA4</li><li>GTM</li>
          </ul>
        </div>
      </div>
    </section>
  </div>

  <section class="section approach">
    <div class="container">
      <div class="section__head">
        <p class="eyebrow">How we work</p>
        <h2>Design, build, measure, optimize</h2>
      </div>
      <ol class="steps" role="list">
        <li class="step"><span class="step__num">01</span><h3 class="step__title">Discover</h3><p class="step__text">Goals, audience, and data: defining what success looks like.</p></li>
        <li class="step"><span class="step__num">02</span><h3 class="step__title">Build</h3><p class="step__text">Design and engineer fast, accessible experiences.</p></li>
        <li class="step"><span class="step__num">03</span><h3 class="step__title">Measure</h3><p class="step__text">Instrument analytics correctly from day one.</p></li>
        <li class="step"><span class="step__num">04</span><h3 class="step__title">Optimize</h3><p class="step__text">Test, refine, and grow conversion over time.</p></li>
      </ol>
    </div>
  </section>

  <section class="section">
    <div class="container cta">
      <h2 class="cta__title">Not sure where to start?</h2>
      <p class="cta__text">Tell us about your project and we'll point you to the right mix.</p>
      <a class="btn btn--primary" href="/about#contact">Get in touch</a>
    </div>
  </section>
</BaseLayout>
