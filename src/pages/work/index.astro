---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/pages/work.css";
---

<BaseLayout
  title="Work &amp; case studies · meemur"
  description="Selected work from meemur. Our first case study is this very site: a fast, accessible, fully measurable marketing site we designed and built end to end."
  canonical="https://meemur.com/work"
  pageClass="page-work"
  active="work"
  ogTitle="Work &amp; case studies · meemur"
  ogDescription="Our first case study is this very site, designed and built by meemur, end to end."
  locale="en"
>
  <section class="section page-hero">
    <div class="container">
      <p class="eyebrow">Portfolio</p>
      <h1>Our <span>work</span></h1>
      <p class="lead">
        Our first case study is this very site, designed, built, and measured end to end,
        and backed by 10+ years and 60+ brands of experience. Yours could be next.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__head">
        <p class="eyebrow">Selected work</p>
        <h2>Recent work</h2>
        <p class="lead">
          meemur.com is our own studio site, designed, built, and measured end to end.
        </p>
      </div>

      <div class="work-grid">
        <a class="work-card" href="/">
          <div class="work-card__media">
            <span class="work-card__badge">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><circle cx="12" cy="12" r="5" /></svg>
              Active
            </span>
            <img src="/work/shot-home.png" alt="The meemur.com home page" width="880" height="550" loading="lazy" />
          </div>
          <div class="work-card__body">
            <h3 class="work-card__title">meemur.com</h3>
            <p class="work-card__desc">
              Our own studio site, built end to end: marketing pages, a spam-protected
              contact form wired to email, and analytics from day one. Fast, accessible,
              and fully measurable.
            </p>
            <div class="work-card__foot">
              <span class="work-card__metric">Fast · Accessible · Measured</span>
              <span class="work-card__view">View site
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14" /><path d="m12 5 7 7-7 7" /></svg>
              </span>
            </div>
          </div>
        </a>

        <article class="work-card">
          <div class="work-card__media">
            <span class="work-card__badge">
              <svg viewBox="0 -960 960 960" fill="currentColor" aria-hidden="true"><path d="M756-120 537-339l84-84 219 219-84 84Zm-552 0-84-84 276-276-68-68-28 28-51-51v82l-28 28-121-121 28-28h82l-50-50 142-142q20-20 43-29t47-9q24 0 47 9t43 29l-92 92 50 50-28 28 68 68 90-90q-4-11-6.5-23t-2.5-24q0-59 40.5-99.5T701-841q15 0 28.5 3t27.5 9l-99 99 72 72 99-99q7 14 9.5 27.5T841-701q0 59-40.5 99.5T701-561q-12 0-24-2t-23-7L204-120Z" /></svg>
              In development
            </span>
            <img src="/work/shot-magcafe.png" alt="The MAG Cafe Study Hub website" width="880" height="550" loading="lazy" />
          </div>
          <div class="work-card__body">
            <h3 class="work-card__title">MAG Cafe Study Hub</h3>
            <p class="work-card__desc">
              A bold, type-led site for a Sincan café and study space: menu, services, and gallery,
              with light and dark themes.
            </p>
            <div class="work-card__foot">
              <span class="work-card__metric">Branding · Astro · Cloudflare</span>
            </div>
          </div>
        </article>

        <article class="work-card">
          <div class="work-card__media">
            <span class="work-card__badge">
              <svg viewBox="0 -960 960 960" fill="currentColor" aria-hidden="true"><path d="M756-120 537-339l84-84 219 219-84 84Zm-552 0-84-84 276-276-68-68-28 28-51-51v82l-28 28-121-121 28-28h82l-50-50 142-142q20-20 43-29t47-9q24 0 47 9t43 29l-92 92 50 50-28 28 68 68 90-90q-4-11-6.5-23t-2.5-24q0-59 40.5-99.5T701-841q15 0 28.5 3t27.5 9l-99 99 72 72 99-99q7 14 9.5 27.5T841-701q0 59-40.5 99.5T701-561q-12 0-24-2t-23-7L204-120Z" /></svg>
              In development
            </span>
            <img src="/work/shot-isiktas.png" alt="The Işıktaş Eğitim Kurumları website" width="880" height="550" loading="lazy" />
          </div>
          <div class="work-card__body">
            <h3 class="work-card__title">Işıktaş Eğitim Kurumları</h3>
            <p class="work-card__desc">
              A conversion-focused site for an Ankara education centre: courses, a trial-exam club,
              and direct WhatsApp contact.
            </p>
            <div class="work-card__foot">
              <span class="work-card__metric">React · Vite · Lead gen</span>
            </div>
          </div>
        </article>

        <a class="work-card work-card--invite" href="/about#contact">
          <p class="eyebrow">Next</p>
          <h3 class="work-card__title">Your project here</h3>
          <p class="work-card__desc">
            We're partnering with a small number of early clients. Let's make your site the next
            case study.
          </p>
          <span class="work-card__view">Start a project
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14" /><path d="m12 5 7 7-7 7" /></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container cta">
      <h2 class="cta__title">Want to be our next case study?</h2>
      <p class="cta__text">
        We're partnering with a small number of early clients. If that sounds like you, let's
        build something worth writing about.
      </p>
      <div class="cta__actions">
        <a class="btn btn--primary" href="/about#contact">Start a project</a>
        <a class="btn btn--outline-light" href="/services">Explore services</a>
      </div>
    </div>
  </section>
</BaseLayout>
