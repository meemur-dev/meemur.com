---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getDictionary } from "../i18n/utils";
import "../styles/pages/notfound.css";

// Cloudflare Pages serves this single 404 for every not-found route, including
// ones under /tr (the directory build format means there is no /tr/404.html).
// So we render English and swap to Turkish at runtime when the path is /tr/*.
const en = getDictionary("en").pages.notfound;
const tr = getDictionary("tr").pages.notfound;
---

<BaseLayout
  title={en.metaTitle}
  description={en.metaDescription}
  canonical=""
  pageClass="page-notfound"
  noindex={true}
  locale="en"
>
  <section class="section notfound">
    <div class="container notfound__inner">
      <p class="eyebrow" data-tr={tr.eyebrow}>{en.eyebrow}</p>
      <span class="notfound__code" aria-hidden="true">404</span>
      <h1 data-tr={tr.title}>{en.title}</h1>
      <p class="lead" data-tr={tr.lead}>{en.lead}</p>
      <div class="notfound__actions">
        <a class="btn btn--primary" href="/" data-tr-href="/tr/" data-tr={tr.backHome}>{en.backHome}</a>
        <a class="btn btn--ghost" href="/services" data-tr-href="/tr/services" data-tr={tr.exploreServices}>
          {en.exploreServices}
        </a>
      </div>
      <p class="notfound__hint" data-tr={tr.hintPlain}>
        {en.hintBefore}<a href="mailto:contact@meemur.com">contact@meemur.com</a>{en.hintAfter}
      </p>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ trTitle: tr.metaTitle }}>
  if (window.location.pathname.startsWith("/tr")) {
    document.querySelectorAll("[data-tr]").forEach((el) => {
      el.textContent = el.getAttribute("data-tr");
    });
    document.querySelectorAll("[data-tr-href]").forEach((el) => {
      el.setAttribute("href", el.getAttribute("data-tr-href"));
    });
    document.title = trTitle;
    document.documentElement.lang = "tr";
  }
</script>
