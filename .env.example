# Build-time env vars (Astro SSG — prefix with PUBLIC_)
# Set these when running `astro build` or in your CI/CD pipeline.
PUBLIC_TURNSTILE_SITEKEY=

# Runtime env vars (Cloudflare Pages Functions)
# Set these in the Cloudflare Pages dashboard (Production / Preview) or
# in your .dev.vars file for local dev with `wrangler pages dev`.
# RESEND_API_KEY=
# TURNSTILE_SECRET_KEY=
# CONTACT_TO=contact@meemur.com
# CONTACT_FROM=meemur <contact@send.meemur.com>
# SUBSCRIBE_TO=contact@meemur.com
