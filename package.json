{
  "name": "meemur-com",
  "version": "0.5.2",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "license": "UNLICENSED",
  "description": "meemur.com, digital agency website",
  "scripts": {
    "dev": "astro dev",
    "predev": "node scripts/build-version.mjs",
    "build": "node scripts/build-version.mjs && astro build && cp -R functions/ dist/functions/",
    "preview": "bun run build && wrangler pages dev ./dist",
    "deploy": "bun run build && wrangler pages deploy ./dist --project-name meemur-com",
    "stamp": "node scripts/build-version.mjs",
    "release": "node scripts/release.mjs",
    "check:version": "node scripts/check-version.mjs",
    "design:lint": "designmd lint DESIGN.md",
    "lint:html": "html-validate \"dist/**/*.html\""
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.7.0",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^6.4.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250303.0",
    "@google/design.md": "^0.2.0",
    "html-validate": "^11.5.3",
    "typescript": "^5.7.0",
    "wrangler": "^4.96.0"
  }
}
